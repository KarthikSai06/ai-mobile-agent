    <style name="TextAppearance.AgentBridge.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.AgentBridge.Value" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>
    <style name="Theme.AgentBridge" parent="Theme.Material3.Dark.NoActionBar">
        
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorPrimaryContainer">#2E1065</item>
        <item name="colorOnPrimaryContainer">@color/accent_purple_light</item>

        
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="colorSecondaryContainer">#0D2E26</item>

        
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_card</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        
        <item name="colorOutline">@color/divider</item>

        
        <item name="colorError">@color/accent_red</item>

        
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>

        
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="Widget.AgentBridge.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent_purple</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>
    <style name="Widget.AgentBridge.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>
