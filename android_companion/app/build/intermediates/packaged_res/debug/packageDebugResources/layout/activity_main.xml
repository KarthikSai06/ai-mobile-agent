<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".MainActivity">

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════ HEADER ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="56dp"
                android:paddingBottom="24dp"
                android:paddingHorizontal="24dp"
                android:gravity="center_horizontal">

                <!-- Logo Circle -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/shape_logo_circle">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="🤖"
                        android:textSize="36sp" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.01" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/app_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ══════════ STATUS CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_status"
                style="@style/Widget.AgentBridge.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!-- Section label -->
                    <TextView
                        android:id="@+id/lbl_status_section"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/status_label"
                        style="@style/TextAppearance.AgentBridge.Label"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Status dot glow ring (pulse animation target) -->
                    <FrameLayout
                        android:id="@+id/status_dot_ring"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/shape_status_dot"
                        android:alpha="0.3"
                        android:contentDescription="@null"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/lbl_status_section"
                        app:layout_constraintBottom_toBottomOf="parent"
                        android:layout_marginTop="16dp"
                        app:layout_constraintVertical_bias="0" />

                    <!-- Status dot core -->
                    <View
                        android:id="@+id/status_dot"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/shape_status_dot"
                        android:contentDescription="@string/cd_status_dot"
                        app:layout_constraintStart_toStartOf="@id/status_dot_ring"
                        app:layout_constraintEnd_toEndOf="@id/status_dot_ring"
                        app:layout_constraintTop_toTopOf="@id/status_dot_ring"
                        app:layout_constraintBottom_toBottomOf="@id/status_dot_ring" />

                    <!-- Status text -->
                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/status_inactive"
                        android:textColor="@color/text_primary"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginStart="12dp"
                        app:layout_constraintStart_toEndOf="@id/status_dot_ring"
                        app:layout_constraintEnd_toStartOf="@id/tv_node_count_inline"
                        app:layout_constraintTop_toTopOf="@id/status_dot_ring"
                        app:layout_constraintBottom_toBottomOf="@id/status_dot_ring" />

                    <!-- Inline node count badge -->
                    <TextView
                        android:id="@+id/tv_node_count_inline"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="#252550"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:text="0 nodes"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-mono"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/status_dot_ring"
                        app:layout_constraintBottom_toBottomOf="@id/status_dot_ring" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ NETWORK INFO ROW ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <!-- IP Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_ip"
                    style="@style/Widget.AgentBridge.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_device_ip"
                            style="@style/TextAppearance.AgentBridge.Label" />

                        <TextView
                            android:id="@+id/tv_ip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/ip_unknown"
                            android:textColor="@color/accent_cyan"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-mono"
                            android:maxLines="1"
                            android:ellipsize="end" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Port Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_port"
                    style="@style/Widget.AgentBridge.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_port"
                            style="@style/TextAppearance.AgentBridge.Label" />

                        <TextView
                            android:id="@+id/tv_port"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="7070"
                            android:textColor="@color/accent_purple_light"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-mono" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══════════ FULL URL CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_url"
                style="@style/Widget.AgentBridge.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/lbl_endpoint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_endpoint"
                        style="@style/TextAppearance.AgentBridge.Label"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_full_url"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="http://—.—.—.—:7070"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-mono"
                        android:maxLines="2"
                        android:ellipsize="end"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/btn_copy"
                        app:layout_constraintTop_toBottomOf="@id/lbl_endpoint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_copy"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="@string/cd_copy"
                        app:icon="@android:drawable/ic_menu_share"
                        app:iconTint="@color/accent_cyan"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ STATS ROW ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <!-- Nodes stat -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.AgentBridge.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔍  Nodes"
                            style="@style/TextAppearance.AgentBridge.Label" />

                        <TextView
                            android:id="@+id/tv_node_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ui elements"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Actions stat -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.AgentBridge.Card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚡  Actions"
                            style="@style/TextAppearance.AgentBridge.Label" />

                        <TextView
                            android:id="@+id/tv_action_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:fontFamily="sans-serif-light" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="dispatched"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ══════════ ENABLE BUTTON ══════════ -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_enable_service"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                android:text="@string/btn_enable_service"
                android:textColor="@color/text_on_accent"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="false"
                android:background="@drawable/btn_primary"
                app:cornerRadius="12dp"
                app:rippleColor="#33FFFFFF" />

            <!-- ══════════ SETUP INSTRUCTIONS CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.AgentBridge.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:strokeColor="#7C3AED"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/instructions_title"
                        style="@style/TextAppearance.AgentBridge.Label"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/instructions_body"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.5" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════ ACTIVITY LOG CARD ══════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_log"
                style="@style/Widget.AgentBridge.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/log_title"
                        style="@style/TextAppearance.AgentBridge.Label"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_log"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/log_waiting"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-mono"
                        android:lineSpacingMultiplier="1.6"
                        android:maxLines="12"
                        android:ellipsize="start" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
